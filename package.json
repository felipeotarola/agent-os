{
  "name": "agent-os",
  "version": "1.0.0",
  "private": true,
  "author": {
    "name": "Agent OS"
  },
  "scripts": {
    "check:memory-control-plane": "node scripts/memory-control-plane-contract.mjs",
    "check:memory-control-plane-runner": "node scripts/memory-control-plane-runner-contract.mjs",
    "memory:control-plane": "node scripts/run-memory-control-plane.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix && bun format",
    "lint:strict": "oxlint --deny-warnings",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepare": "husky",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:studio": "drizzle-kit studio",
    "check:runtime-mocks": "node scripts/check-runtime-mocks.mjs && node scripts/check-theme-containers.mjs && node scripts/check-openclaw-runtime-contract.mjs && node scripts/check-openclaw-runtime-contract-fixtures.mjs",
    "check:openclaw-runtime": "node scripts/check-openclaw-runtime-contract.mjs --runtime",
    "check:proactivity": "node scripts/proactivity-regression-harness.mjs",
    "check:qa-strategy": "node scripts/qa-strategy-contract-harness.mjs",
    "check:qaa-positioning": "node scripts/qaa-positioning-guard.mjs",
    "lab:weekly": "node scripts/weekly-wild-lab.mjs",
    "self-evolution:research": "node scripts/self-evolution-research-lane.mjs",
    "brief:local": "node scripts/local-daily-brief.mjs",
    "brief:heartbeat": "node scripts/heartbeat-local-brief.mjs",
    "car:polestar:setup": "node scripts/setup-polestar-api.mjs",
    "car:polestar:brief": "node scripts/polestar-vehicle-brief.mjs",
    "price:tibber": "node scripts/tibber-electricity-price.mjs",
    "tasks:life-os-export": "node scripts/export-life-os-task-candidates.mjs",
    "lessons:corrections": "node scripts/correction-lesson-router.mjs",
    "check:self-improvement-readiness": "node scripts/self-improvement-readiness.mjs",
    "check:cron-tool-policy": "node scripts/cron-tool-policy-preflight.mjs",
    "check:cron-lane-visibility": "node scripts/cron-lane-visibility-preflight.mjs",
    "check:repo-review-preflight": "node scripts/repo-review-preflight.mjs",
    "check:cron-review-preflight": "node scripts/cron-review-preflight.mjs",
    "git:push": "node scripts/git-push-agent-os-token.mjs",
    "prebuild": "npm run check:runtime-mocks",
    "typecheck": "tsc --noEmit",
    "verify": "npm run check:runtime-mocks && npm run check:memory-control-plane && npm run check:memory-control-plane-runner && npm run check:proactivity && npm run evals:agent && npm run check:self-improvement-readiness && npm run check:cron-tool-policy && npm run check:cron-lane-visibility && npm run check:cron-review-preflight && npm run check:qa-strategy && npm run check:qaa-positioning && npm run check:repo-review-preflight && npm run lint && npm run typecheck",
    "evals:agent": "node scripts/agent-evals.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.39.1",
    "@clerk/themes": "^2.4.57",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
